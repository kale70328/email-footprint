# Copy this file to .env.local and fill in your keys

# Have I Been Pwned API (https://haveibeenpwned.com/API/Key)
HIBP_API_KEY=

# Resend email API (https://resend.com)
RESEND_API_KEY=

# Redis for OTP storage (optional - uses in-memory store if omitted)
REDIS_URL=redis://localhost:6379

# App URL (used for email verification links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
